# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (local via Docker)
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/whatsapp_food_bot

# Redis (local via Docker)
REDIS_URL=redis://localhost:6379

# ─── WhatsApp Provider: "twilio" or "meta" ───
WA_PROVIDER=twilio

# ─── Twilio WhatsApp Sandbox ───
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Meta Cloud API (leave blank if using Twilio) ───
# WA_PHONE_NUMBER_ID=your_phone_number_id
# WA_ACCESS_TOKEN=your_access_token
# WA_VERIFY_TOKEN=your_verify_token
# WA_APP_SECRET=your_app_secret
WA_API_VERSION=v21.0

# ─── Razorpay (optional — leave blank for demo/free mode) ───
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Google Maps (optional — for reverse geocoding) ───
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Admin API key
ADMIN_API_KEY=your_admin_api_key
